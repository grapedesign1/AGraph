/* ============================================
   AccelCurve Extension v4.8 - Integrated Styles
   ============================================ */

/* Reset & Base */
@import url("https://cdnjs.cloudflare.com/ajax/libs/meyer-reset/2.0/reset.min.css");
@import url("https://fonts.googleapis.com/css?family=Roboto:400");

/* Design Tokens */
:root { 
  --black: #000000;
  --eerie-black: #1e1e1e;
  --fuscous-gray: #555555;
  --nobel: #b0b1b0;
  --robins-egg-blue: #00c0e8;
  --dark-bg: #2b2b2b;
  --panel-bg: #333333;
  --dark-gray: #1a1a1a;
  --resize-bar: #8e8e93;
  --velocity: #34C759;
  --accent-red: #FF2D55;
 
  --font-size-m: 11px;
  --font-family-roboto: "Roboto", Helvetica;
}

/* Global Styles */
* {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
  font-family: var(--font-family-roboto);
  font-size: var(--font-size-m);
  color: var(--nobel);
  background-color: var(--dark-bg);
}

.screen {
  min-width: 240px;
  min-height: 100vh;
  width: 100%;
  height: 100%;
}

.screen a {
  display: contents;
  text-decoration: none;
}

/* Typography */
.bouutn {
  font-family: var(--font-family-roboto);
  font-size: var(--font-size-m);
  font-style: normal;
  font-weight: 400;
  letter-spacing: 0;
}

/* ============================================
   Common Components (Shared between layouts)
   ============================================ */

/* Graph Container */
.div-graph {
  align-items: center;
  background-color: var(--eerie-black);
  border: 1px solid;
  border-color: var(--fuscous-gray);
  border-radius: 3px;
  flex: 1;
  min-height: 0;
  aspect-ratio: 1;
  justify-content: center;
  display: flex;
  position: relative;
}

.graph {
  position: relative;
  width: 100%;
  height: 100%;
}

/* Graph UI Overlay */
.graph-ui {
  align-items: flex-end;
  display: inline-flex;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 4px;
  justify-content: center;
  padding: 4px;
  position: absolute;
  right: 0;
  top: 0;
}

/* Toggle Buttons */
.toggle-checkbox {
  display: none;
}

.velocity-toggle {
  aspect-ratio: 1;
  height: 16px;
  position: relative;
  width: 16px;
  background-color: var(--velocity);
  border: 0px none;
  border-radius: 3px;
  cursor: pointer;
  transition: opacity 0.2s;
  opacity: 0.3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.velocity-toggle.checked {
  opacity: 0.8;
}

.velocity-toggle:not(.checked):hover {
  opacity: 0.8;
}

.acceleration-toggle {
  aspect-ratio: 1;
  background-color: var(--accent-red);
  border: 0px none;
  border-radius: 3px;
  height: 16px;
  position: relative;
  width: 16px;
  cursor: pointer;
  transition: opacity 0.2s;
  opacity: 0.3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.acceleration-toggle.checked {
  opacity: 0.8;
}

.acceleration-toggle:not(.checked):hover {
  opacity: 0.8;
}

.v {
  aspect-ratio: 0.8;
  height: 10px;
  left: 4px;
  position: absolute;
  top: 3px;
  width: 8px;
}

.a {
  aspect-ratio: 0.8;
  height: 10px;
  left: 4px;
  position: absolute;
  top: 3px;
  width: 8px;
  pointer-events: none;
}

/* Utility Buttons */
.x-button {
  aspect-ratio: 1;
  background-color: var(--eerie-black);
  border-radius: 3px;
  height: 16px;
  position: relative;
  width: 16px;
  border: 0;
  cursor: pointer;
  transition: background-color 0.2s;
}

.x-button:hover {
  background-color: var(--fuscous-gray);
}

.maximize-2 {
  aspect-ratio: 1;
  height: 14px;
  left: 1px;
  position: absolute;
  top: 1px;
  width: 14px;
  pointer-events: none;
}

.type {
  aspect-ratio: 1;
  height: 12px;
  left: 2px;
  position: absolute;
  top: 2px;
  width: 12px;
  pointer-events: none;
}

.group-1 {
  aspect-ratio: 1;
  height: 12px;
  left: 2px;
  position: relative;
  top: 2px;
  width: 12px;
}

.rectangle-1 {
  background-color: var(--nobel);
  left: 1px;
  top: 0;
}

.rectangle-2 {
  border-color: var(--nobel);
  left: 3px;
  top: 3px;
  transform: rotate(90.00deg);
}

/* Action Buttons */
.e-button {
  align-items: center;
  background-color: var(--eerie-black);
  border: 1px solid;
  border-color: var(--fuscous-gray);
  border-radius: 30px;
  display: flex;
  flex: 1;
  flex-grow: 1;
  gap: 6px;
  height: 24px;
  justify-content: center;
  min-width: 60px;
  padding: 0 8px;
  position: relative;
  cursor: pointer;
  transition: all 0.2s;
  user-select: none;
}

.e-button:hover {
  background-color: #2a2a2a;
}

.e-button:active {
  transform: translateY(1px);
}

.icon-1,
.icon-2,
.icon-3 {
  margin-bottom: -2.00px;
  margin-top: -2.00px;
  position: relative;
  pointer-events: none;
}

.group {
  background-image: url(img/vector-4.svg);
  background-size: 100% 100%;
  height: 100%;
  position: relative;
}

.vector {
  height: 36.16%;
  left: 40.35%;
  position: absolute;
  top: 41.58%;
  width: 36.16%;
}

.analyze,
.save {
  align-items: center;
  color: var(--nobel);
  display: flex;
  font-weight: 400;
  justify-content: center;
  line-height: normal;
  position: relative;
  text-align: center;
  white-space: nowrap;
  width: fit-content;
  pointer-events: none;
}

/* Apply Button (Primary) */
.apply-button {
  background-color: var(--eerie-black);
  border: 1px solid;
  border-color: var(--robins-egg-blue);
  border-radius: 30px;
  flex: 1;
  flex-grow: 1;
  gap: 6px;
  height: 24px;
  min-width: 60px;
  padding: 0 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
  user-select: none;
}

.apply-button:hover {
  background-color: #1a3f4a;
}

.apply-button:active {
  transform: translateY(1px);
}

.icon-2 {
  background-image: url(img/vector-6.svg);
  background-size: 100% 100%;
  margin-bottom: -2.00px;
  margin-top: -2.00px;
  position: relative;
}

.apply {
  color: var(--robins-egg-blue);
  font-weight: 400;
  line-height: normal;
  text-align: center;
  white-space: nowrap;
  width: fit-content;
  pointer-events: none;
}

.icon-3 {
  background-image: url(img/vector-7.svg);
  background-size: 100% 100%;
  margin-bottom: -2.00px;
  margin-top: -2.00px;
  position: relative;
}

/* Group Name Pulldown */
.name-pulldown {
  background-color: var(--eerie-black);
  border: 1px solid;
  border-color: var(--fuscous-gray);
  border-radius: 3px;
  flex: 1;
  flex-grow: 1;
  height: 20px;
  min-width: 60px;
  position: relative;
  padding: 2px 6px;
  color: var(--nobel);
  font-size: var(--font-size-m);
  font-family: var(--font-family-roboto);
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  user-select: none;
}

.group-name-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pulldown-icon {
  width: 9px;
  height: 6px;
  margin-left: 6px;
  flex-shrink: 0;
  opacity: 0.8;
}

.name-pulldown:hover {
  border-color: var(--nobel);
}

/* Group Control Buttons */
.x-button-1 {
  background-color: var(--eerie-black);
  border-radius: 3px;
  height: 20px;
  position: relative;
  width: 20px;
  border: 0;
  cursor: pointer;
  transition: background-color 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.x-button-1:hover {
  background-color: var(--fuscous-gray);
}

.icon {
  left: 4px;
  position: absolute;
  top: 4px;
  pointer-events: none;
}

/* Card Size Slider */
.card-size-slider {
  border-radius: 3px;
  height: 20px;
  position: relative;
  width: 60px;
  cursor: pointer;
  user-select: none;
}

.vector-1 {
  height: 1px;
  left: 0;
  object-fit: cover;
  position: absolute;
  top: 10px;
  width: 61px;
  pointer-events: none;
}

.ellipse-1 {
  aspect-ratio: 1;
  background-color: var(--nobel);
  border-radius: 5px;
  height: 10px;
  left: 11px;
  position: absolute;
  top: 5px;
  width: 10px;
  transition: left 0.1s;
  pointer-events: none;
}

/* Resize Bar */
.bar-resize {
  background-color: var(--resize-bar);
  border-radius: 3px;
  position: relative;
  cursor: ns-resize;
  transition: background-color 0.2s;
  user-select: none;
}

.bar-resize:hover {
  background-color: var(--robins-egg-blue);
}

/* Preset Container */
.div-preset {
  align-items: flex-start;
  background-color: var(--dark-gray);
  border: 1px solid;
  border-color: var(--fuscous-gray);
  border-radius: 3px;
  flex-wrap: wrap;
  gap: 8px 8px;
  padding: 8px;
  display: flex;
  overflow-y: auto;
}

.dummy {
  aspect-ratio: 1;
  background-color: var(--eerie-black);
  border: 1px solid var(--fuscous-gray);
  border-radius: 3px;
  position: relative;
  cursor: pointer;
  transition: all 0.2s;
}

.dummy:hover {
  border-color: var(--robins-egg-blue);
  transform: scale(1.05);
}

/* Icon Helpers */
.apply-1 {
  align-items: center;
  display: flex;
  justify-content: center;
  position: relative;
}

.icon-4 {
  aspect-ratio: 1;
  height: 12px;
  width: 12px;
}

.rectangle {
  border: 1px solid;
  border-radius: 1px;
  height: 10px;
  position: absolute;
  width: 7px;
}

/* Hidden Elements (for JS compatibility) */
.hidden {
  display: none !important;
}

#output {
  display: none;
}

/* ============================================
   Vertical Layout (data-layout="vertical")
   ============================================ */

.screen[data-layout="vertical"] {
  align-items: flex-start;
  background-color: var(--dark-bg);
  border: 0px none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  justify-content: center;
  min-height: 100vh;
  min-width: 240px;
  position: relative;
}

.screen[data-layout="vertical"] .main {
  align-items: center;
  align-self: stretch;
  border: 0px none;
  display: flex;
  flex: 1;
  flex-direction: column;
  flex-grow: 1;
  gap: 10px;
  min-width: 240px;
  position: relative;
  width: 100%;
}

.screen[data-layout="vertical"] .mian-div {
  align-items: center;
  align-self: stretch;
  background-color: var(--panel-bg);
  border-radius: 4px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 408px;
  padding: 8px;
  position: relative;
  width: 100%;
}

.screen[data-layout="vertical"] .section-graph {
  gap: 8px;
  display: flex;
  flex-direction: column;
  width: 100%;
  align-items: center;
  flex: 0 0 400px;
  min-height: 150px;
}

.screen[data-layout="vertical"] .section {
  flex-direction: column;
  gap: 8px;
  display: flex;
  width: 100%;
}

.screen[data-layout="vertical"] .div {
  align-items: center;
  align-self: stretch;
  border: 0px none;
  flex: 0 0 auto;
  gap: 4px;
  justify-content: center;
  width: 100%;
  display: flex;
}

.screen[data-layout="vertical"] .bar-resize {
  align-self: stretch;
  height: 4px;
  width: 100%;
  cursor: ns-resize;
}

.screen[data-layout="vertical"] .section-group {
  flex-direction: column;
  gap: 6px;
  display: flex;
  width: 100%;
}

.screen[data-layout="vertical"] .div-preset {
  align-self: stretch;
  flex: 1;
  width: 100%;
  overflow-y: auto;
}

.screen[data-layout="vertical"] .dummy {
  height: 64px;
  width: 64px;
}

.screen[data-layout="vertical"] .div-1 {
  display: flex;
  position: relative;
}

.screen[data-layout="vertical"] .section-1 {
  align-items: stretch;
  align-self: stretch;
  border: 0px none;
  display: flex;
  flex-direction: column;
  flex: 0 0 300px;
  min-height: 150px;
  justify-content: flex-start;
  position: relative;
  width: 100%;
  overflow: hidden;
}

/* ============================================
   Horizontal Layout (data-layout="horizontal")
   ============================================ */

.screen[data-layout="horizontal"] {
  align-items: center;
  background-color: var(--dark-bg);
  border: 0px none;
  display: flex;
  gap: 10px;
  justify-content: center;
  min-height: 100vh;
  min-width: 240px;
  position: relative;
}

.screen[data-layout="horizontal"] .main {
  align-items: center;
  align-self: stretch;
  border: 0px none;
  display: flex;
  flex: 1;
  flex-direction: column;
  flex-grow: 1;
  gap: 10px;
  min-height: 210px;
  min-width: 240px;
  position: relative;
}

.screen[data-layout="horizontal"] .mian-div {
  align-items: flex-start;
  align-self: stretch;
  background-color: var(--panel-bg);
  border-radius: 4px;
  display: flex;
  flex: 1;
  flex-grow: 1;
  gap: 8px;
  min-height: 210px;
  padding: 8px;
  position: relative;
  width: 100%;
}

.screen[data-layout="horizontal"] .section-left {
  display: flex;
  flex: 1;
  flex-direction: column;
  flex-grow: 1;
  gap: 8px;
  min-width: 240px;
}

.screen[data-layout="horizontal"] .section-graph {
  border: 0px none;
  display: flex;
  gap: 8px;
  height: 160px;
  justify-content: center;
  width: 100%;
  flex-direction: column;
}

.screen[data-layout="horizontal"] .section-button {
  border: 0px none;
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 8px;
  justify-content: center;
  width: 100%;
}

.screen[data-layout="horizontal"] .div {
  align-items: center;
  border: 0px none;
  flex: 0 0 auto;
  gap: 4px;
  justify-content: center;
  width: 100%;
  display: flex;
}

.screen[data-layout="horizontal"] .section-resize {
  border: 0px none;
  display: inline-flex;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 8px;
  justify-content: center;
}

.screen[data-layout="horizontal"] .bar-resize {
  flex: 1;
  flex-grow: 1;
  width: 4px;
  cursor: ew-resize;
}

.screen[data-layout="horizontal"] .section-right {
  display: flex;
  flex: 1;
  flex-direction: column;
  flex-grow: 1;
  gap: 8px;
  min-width: 190px;
}

.screen[data-layout="horizontal"] .section-group {
  border: 0px none;
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 6px;
  justify-content: center;
  width: 100%;
}

.screen[data-layout="horizontal"] .section-preset {
  border: 0px none;
  display: flex;
  flex: 1;
  flex-direction: column;
  flex-grow: 1;
  gap: 8px;
  justify-content: center;
  width: 100%;
}

.screen[data-layout="horizontal"] .div-preset {
  flex: 1;
  flex-grow: 1;
  width: 100%;
}

.screen[data-layout="horizontal"] .dummy {
  height: 64px;
}

.screen[data-layout="horizontal"] .dummy-1 {
  height: 22px;
  margin-bottom: -16.00px;
}

.screen[data-layout="horizontal"] .div-1 {
  align-self: stretch;
  display: flex;
  position: relative;
}

.screen[data-layout="horizontal"] .dummy-2 {
  aspect-ratio: 1;
  position: relative;
  width: 64px;
}

.screen[data-layout="horizontal"] .section {
  align-items: center;
  align-self: stretch;
  position: relative;
  display: flex;
}
