<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.grapedesign.agraph" ExtensionBundleVersion="1.0" ExtensionBundleName="AGraph" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
                    <Extension Id="com.grapedesign.agraph" Version="1.0" />
    </ExtensionList>
    
    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[22.0,99.9]"/>
        </HostList>
        
        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>
        
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    
    <DispatchInfoList>
        <Extension Id="com.grapedesign.agraph">
            <DispatchInfo>
                <Resources>
                    <MainPath>./ext/index.html</MainPath>
                    <ScriptPath>./ext/extendscript.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                
                <UI>
                    <Type>Panel</Type>
                    <Menu>AGraph</Menu>
                    <Geometry>
                        <Size>
                            <Width>300</Width>
                            <Height>400</Height>
                        </Size>
                        <MinSize>
                            <Width>250</Width>
                            <Height>300</Height>
                        </MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>